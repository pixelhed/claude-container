#!/bin/bash
## Host: Remove container, volumes, and image

set -e
source "$(dirname "$0")/compose-args"

read -p "⚠️  Delete container, volumes, and image? [y/N] " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    docker compose $COMPOSE_FILES down -v
    docker rmi "$(docker compose $COMPOSE_FILES config --images 2>/dev/null)" 2>/dev/null || true
    echo "✅ Removed."
else
    echo "Cancelled."
fi
