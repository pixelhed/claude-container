#!/bin/bash
## Host: Run Claude Code with --dangerously-skip-permissions inside the container
##
## Usage:
##   bin/claude                              Interactive YOLO mode
##   bin/claude -p "fix all lint errors"     Headless with prompt
##   bin/claude --print "explain this"       Print mode

set -e
source "$(dirname "$0")/compose-args"

if ! docker compose $COMPOSE_FILES ps --status running 2>/dev/null | grep -q claude; then
    echo "Container not running. Starting..."
    docker compose $COMPOSE_FILES up -d
    sleep 2
fi

docker compose $COMPOSE_FILES exec -it claude claude --dangerously-skip-permissions "$@"
