#!/bin/bash
## Host: Show container status and installed versions

source "$(dirname "$0")/compose-args"

echo "── Container ──"
docker compose $COMPOSE_FILES ps 2>/dev/null || echo "Not running"

if docker compose $COMPOSE_FILES ps --status running 2>/dev/null | grep -q claude; then
    echo ""
    echo "── Versions ──"
    docker compose $COMPOSE_FILES exec claude bash -c '
        echo "   claude:      $(claude --version 2>/dev/null || echo "not found")"
        echo "   node:        $(node -v 2>/dev/null)"
        command -v php &>/dev/null && echo "   php:         $(php -v 2>/dev/null | head -1 | awk "{print \$2}")"
        command -v composer &>/dev/null && echo "   composer:    $(composer -V 2>/dev/null | awk "{print \$3}")"
        command -v python3 &>/dev/null && echo "   python:      $(python3 --version 2>/dev/null | awk "{print \$2}")"
    '
    echo ""
    echo "── Workspace ──"
    docker compose $COMPOSE_FILES exec claude bash -c "ls /workspace/ 2>/dev/null | head -20"
    echo ""
    echo "── Ecosystem ──"
    docker compose $COMPOSE_FILES exec claude bash -c \
        "if [ -d /home/node/claude-ecosystem ]; then echo '   ✅ Mounted'; else echo '   ⚠️  Not mounted'; fi"
fi
