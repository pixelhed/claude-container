#!/bin/bash
## Host: Switch n8n MCP between dev and prod environments
##
## Usage:
##   bin/n8n dev         Switch to dev (helios.lan:5678)
##   bin/n8n prod        Switch to prod (n8n.pixelperfect.at)
##   bin/n8n status      Show current environment
##
## Rewrites workspace/.mcp.json — no rebuild or restart needed.
## Just start a new Claude session to pick up the change.

set -e
cd "$(dirname "$0")/.."

ENV_FILE=".env"
MCP_FILE="../workspace/.mcp.json"

# ── Load .env ──
if [ -f "$ENV_FILE" ]; then
    # Source .env, handling lines with = signs
    set -a
    source "$ENV_FILE"
    set +a
fi

# ── Defaults ──
N8N_DEV_URL="${N8N_DEV_URL:-http://helios.lan:5678}"
N8N_DEV_API_KEY="${N8N_DEV_API_KEY:-}"
N8N_PROD_URL="${N8N_PROD_URL:-https://n8n.pixelperfect.at}"
N8N_PROD_API_KEY="${N8N_PROD_API_KEY:-}"

write_mcp() {
    local url="$1"
    local key="$2"
    local env_name="$3"

    cat > "$MCP_FILE" <<MCPEOF
{
  "mcpServers": {
    "n8n-mcp": {
      "command": "npx",
      "args": ["n8n-mcp"],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "$url",
        "N8N_API_KEY": "$key"
      }
    }
  }
}
MCPEOF

    echo "✅ n8n MCP → $env_name ($url)"
    echo "   Written to: $(cd .. && pwd)/workspace/.mcp.json"
    echo "   Start a new Claude session to pick up the change."
}

case "${1:-status}" in
    dev)
        if [ -z "$N8N_DEV_API_KEY" ]; then
            echo "⚠️  N8N_DEV_API_KEY not set in .env — MCP will have doc-only access"
        fi
        write_mcp "$N8N_DEV_URL" "$N8N_DEV_API_KEY" "dev"
        ;;
    prod)
        if [ -z "$N8N_PROD_API_KEY" ]; then
            echo "⚠️  N8N_PROD_API_KEY not set in .env — MCP will have doc-only access"
        fi
        write_mcp "$N8N_PROD_URL" "$N8N_PROD_API_KEY" "prod"
        ;;
    status)
        if [ ! -f "$MCP_FILE" ]; then
            echo "No .mcp.json found. Run: bin/n8n dev  or  bin/n8n prod"
            exit 0
        fi
        # Extract current URL from .mcp.json
        current_url=$(grep -o '"N8N_API_URL":[[:space:]]*"[^"]*"' "$MCP_FILE" | sed 's/.*"//' | sed 's/"$//' | head -1)
        if echo "$current_url" | grep -qi "helios\|localhost\|:5678"; then
            echo "🔧 Current: dev ($current_url)"
        else
            echo "🚀 Current: prod ($current_url)"
        fi
        ;;
    *)
        echo "Usage: bin/n8n [dev|prod|status]"
        exit 1
        ;;
esac
