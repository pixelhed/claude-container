{
  "_comment": "Container-specific Claude Code settings. Copy to settings.container.json.",

  "permissions": {
    "allow": [
      "Read", "Write", "Edit", "MultiEdit",
      "Grep", "Glob", "LS",
      "Bash(git *)", "Bash(cat *)", "Bash(head *)", "Bash(tail *)",
      "Bash(find *)", "Bash(ls *)", "Bash(pwd)",
      "Bash(mkdir *)", "Bash(touch *)", "Bash(cp *)", "Bash(mv *)", "Bash(rm *)",
      "Bash(composer *)", "Bash(php *)",
      "Bash(npm *)", "Bash(npx *)",
      "Bash(python3 *)", "Bash(uv *)",
      "Bash(vendor/bin/*)"
    ],
    "deny": []
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit)",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.php ]] && command -v php-cs-fixer &>/dev/null; then php-cs-fixer fix \"$CLAUDE_FILE_PATH\" --quiet 2>/dev/null || true; fi",
            "timeout": 30
          }
        ]
      }
    ]
  },

  "mcpServers": {
    "n8n": {
      "_comment": "Enable if n8n on Helios is reachable. Also uncomment Tailscale line in bin/firewall.",
      "command": "npx",
      "args": ["-y", "@n8n/mcp-server"],
      "env": {
        "N8N_BASE_URL": "http://helios:5678",
        "N8N_API_KEY": "${N8N_API_KEY}"
      },
      "disabled": true
    },
    "serena": {
      "_comment": "Needs PHPStorm LSP — not available in container",
      "disabled": true
    },
    "browser": {
      "_comment": "No GUI in container",
      "disabled": true
    }
  }
}
